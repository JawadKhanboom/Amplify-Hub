{
  "name": "amplifyhub-sales-mindset",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/build-fingerprint.mjs --write",
    "fingerprint:check": "node scripts/build-fingerprint.mjs --check",
    "typecheck": "tsc --noEmit --pretty false",
    "preview": "vite preview",
    "qa": "node scripts/qa.mjs",
    "qa:booking": "node scripts/qa-booking.mjs",
    "qa:progress": "node scripts/qa-progress.mjs",
    "qa:coach-security": "node scripts/qa-coach-request-security.mjs && node scripts/qa-coach-security.mjs",
    "qa:challenges": "node scripts/qa-challenges.mjs",
    "qa:resources": "node scripts/qa-resources.mjs",
    "generate:resources": "node scripts/generate-resource-files.mjs",
    "generate:resource-migration": "node scripts/generate-resource-migration.mjs",
    "qa:profile-progress": "node scripts/qa-profile-progress.mjs",
    "qa:account-trust": "node scripts/qa-account-trust.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "monitor:health": "node scripts/monitor-health.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.8",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "playwright-core": "1.61.1",
    "typescript": "7.0.2",
    "vite": "8.1.5"
  }
}
